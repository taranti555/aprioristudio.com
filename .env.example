# Apriori Studio — contact form endpoint configuration
# Copy to .env on the server and fill in real values.

# MySQL on ru128 (private network or whitelisted IP)
APRIORI_DB_HOST=127.0.0.1
APRIORI_DB_NAME=aprioristudio
APRIORI_DB_USER=aprioristudio_app
APRIORI_DB_PASS=change-me

# Outbound SMTP via mailcow on ru48
APRIORI_SMTP_HOST=mail.pogosov.com
APRIORI_SMTP_PORT=587
APRIORI_SMTP_USER=noreply@aprioristudio.com
APRIORI_SMTP_PASS=change-me

# Recipients of contact form notifications (comma-separated)
APRIORI_NOTIFY_TO=mp@aprioristudio.com,np@aprioristudio.com
