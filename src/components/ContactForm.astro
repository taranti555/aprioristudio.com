---
// No props — self-contained.
---
<form id="contact-form" class="space-y-5" novalidate>
  <div>
    <label for="cf-name" class="block text-sm font-medium mb-1.5">
      Your name <span class="text-[var(--color-accent)]">*</span>
    </label>
    <input
      type="text"
      id="cf-name"
      name="name"
      required
      autocomplete="name"
      maxlength="120"
      class="w-full px-3.5 py-2.5 bg-white border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 transition"
    />
  </div>

  <div>
    <label for="cf-email" class="block text-sm font-medium mb-1.5">
      Email <span class="text-[var(--color-accent)]">*</span>
    </label>
    <input
      type="email"
      id="cf-email"
      name="email"
      required
      autocomplete="email"
      maxlength="190"
      class="w-full px-3.5 py-2.5 bg-white border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 transition"
    />
  </div>

  <div>
    <label for="cf-subject" class="block text-sm font-medium mb-1.5">
      Subject <span class="text-[var(--color-ink-soft)] font-normal">(optional)</span>
    </label>
    <input
      type="text"
      id="cf-subject"
      name="subject"
      maxlength="200"
      placeholder="What's it about?"
      class="w-full px-3.5 py-2.5 bg-white border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 transition"
    />
  </div>

  <div>
    <label for="cf-message" class="block text-sm font-medium mb-1.5">
      Message <span class="text-[var(--color-accent)]">*</span>
    </label>
    <textarea
      id="cf-message"
      name="message"
      required
      rows="6"
      minlength="20"
      maxlength="5000"
      placeholder="Tell us about your project, your timeline, and any constraints we should know about."
      class="w-full px-3.5 py-2.5 bg-white border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 transition resize-y"
    ></textarea>
  </div>

  <!-- Honeypot: hidden from users, bots fill it -->
  <div style="position:absolute; left:-9999px; height:0; overflow:hidden;" aria-hidden="true">
    <label for="cf-website">Website (leave empty)</label>
    <input type="text" id="cf-website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <input type="hidden" name="ts" id="cf-ts" />

  <button
    type="submit"
    id="cf-submit"
    class="btn-primary w-full sm:w-auto justify-center text-base"
  >
    Send message →
  </button>

  <p id="cf-status" role="status" aria-live="polite" class="text-sm hidden"></p>
</form>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('cf-status');
    const submit = document.getElementById('cf-submit');
    const tsField = document.getElementById('cf-ts');
    if (!form) return;

    tsField.value = String(Math.floor(Date.now() / 1000));

    function showStatus(msg, kind) {
      status.textContent = msg;
      status.classList.remove('hidden', 'text-green-600', 'text-red-600', 'text-[var(--color-ink-soft)]');
      if (kind === 'ok') status.classList.add('text-green-600');
      else if (kind === 'err') status.classList.add('text-red-600');
      else status.classList.add('text-[var(--color-ink-soft)]');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submit.disabled = true;
      submit.textContent = 'Sending…';
      showStatus('', 'info');

      try {
        const data = new FormData(form);
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' },
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok && json.ok) {
          form.reset();
          showStatus('Thank you. We received your message and will reply within two business days.', 'ok');
          submit.style.display = 'none';
        } else {
          showStatus(json.error || 'Something went wrong. Please try again or email us directly.', 'err');
          submit.disabled = false;
          submit.textContent = 'Send message →';
        }
      } catch (err) {
        showStatus('Network error. Please try again or email us directly.', 'err');
        submit.disabled = false;
        submit.textContent = 'Send message →';
      }
    });
  })();
</script>
