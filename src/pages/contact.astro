---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactForm from '../components/ContactForm.astro';
import Email from '../components/Email.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE } from '../lib/site';

const title = 'Contact Apriori Studio';
const description =
  'Get in touch with Apriori Studio about a website or mobile app project. We reply to all enquiries within two business days.';

const ld = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: title,
  description,
  url: SITE.url + '/contact',
  mainEntity: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};
---

<BaseLayout title={title} description={description}>
  <Hero image="/heroes/contact.webp" tint="navy">
    <span class="kicker text-amber-300">Get in touch</span>
    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight leading-[1.05] hero-shadow">
      Tell us about<br class="hidden md:block" /> your project
    </h1>
    <p class="mt-5 text-lg text-slate-200/95 max-w-2xl hero-shadow">
      We reply to every enquiry within two business days. The more you tell us, the more useful
      our first reply will be.
    </p>
  </Hero>

  <article class="max-w-3xl mx-auto px-5 py-12 md:py-16">
    <Breadcrumbs items={[
      { href: '/', label: 'Home' },
      { href: '/contact', label: 'Contact' },
    ]} />

    <div class="grid md:grid-cols-3 gap-10 md:gap-14">
      <section class="md:col-span-2">
        <ContactForm />
      </section>

      <aside class="space-y-6 text-sm">
        <div>
          <h2 class="font-semibold text-[var(--color-ink)] mb-2">Email</h2>
          <p>
            <Email address={SITE.email.contact} class="text-[var(--color-accent)] hover:underline" />
          </p>
          <p class="text-[var(--color-ink-soft)] text-xs mt-1">
            Goes straight to the studio team.
          </p>
        </div>

        <div>
          <h2 class="font-semibold text-[var(--color-ink)] mb-2">Studio</h2>
          <p class="text-[var(--color-ink-soft)] leading-relaxed">
            Apriori Ltd<br />
            London, England<br />
            United Kingdom
          </p>
        </div>

        <div>
          <h2 class="font-semibold text-[var(--color-ink)] mb-2">What we'll ask</h2>
          <ul class="text-[var(--color-ink-soft)] space-y-1.5 leading-relaxed">
            <li>What you're trying to build</li>
            <li>Who it's for</li>
            <li>Your timeline</li>
            <li>Your budget range, if you have one</li>
          </ul>
        </div>

        <div class="text-xs text-[var(--color-ink-soft)] leading-relaxed pt-4 border-t border-[var(--color-border)]">
          We treat every enquiry as confidential. We don't share your information with third
          parties or send you marketing email. See our <a href="/privacy" class="text-[var(--color-accent)] hover:underline">privacy policy</a>.
        </div>
      </aside>
    </div>

    <JsonLd data={ld} />
  </article>
</BaseLayout>
