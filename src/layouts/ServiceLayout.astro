---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE } from '../lib/site';

interface Crumb { href: string; label: string; }
interface Props {
  title: string;
  description: string;
  serviceType: string;
  serviceArea?: string;
  breadcrumbs: Crumb[];
}

const { title, description, serviceType, serviceArea = 'Worldwide', breadcrumbs } = Astro.props;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType,
  name: title,
  description,
  provider: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  areaServed: serviceArea,
  url: new URL(Astro.url.pathname, SITE.url).toString(),
};
---
<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-5 py-10 md:py-14">
    <Breadcrumbs items={breadcrumbs} />
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-semibold text-[var(--color-ink)] tracking-tight leading-tight">
        {title}
      </h1>
      <p class="mt-3 text-lg text-[var(--color-ink-soft)]">{description}</p>
    </header>

    <div class="prose-body">
      <slot />
    </div>

    <aside class="mt-14 p-6 bg-[var(--color-ink)] text-white rounded-xl">
      <h2 class="text-xl font-semibold mb-2">Ready to start?</h2>
      <p class="text-slate-300 text-sm leading-relaxed mb-4">
        Tell us what you have in mind. We'll come back with a clear quote and timeline within two business days.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] rounded-lg font-medium transition-colors text-sm">
        Get in touch →
      </a>
    </aside>
  </article>

  <JsonLd data={serviceLd} />
</BaseLayout>
