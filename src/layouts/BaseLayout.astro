---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  canonical?: string;
}

const { title, description, ogImage = '/og-default.png', noIndex = false, canonical } = Astro.props;

const fullTitle = title === SITE.name ? title : `${title} — ${SITE.name}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname.replace(/\/$/, '') || '/', SITE.url).toString();
const ogImageUrl = new URL(ogImage, SITE.url).toString();

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  legalName: SITE.legalName,
  url: SITE.url,
  logo: new URL('/logo.svg', SITE.url).toString(),
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    addressCountry: SITE.address.country,
    addressRegion: SITE.address.region,
    addressLocality: SITE.address.locality,
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      url: SITE.url + '/contact',
      availableLanguage: ['English'],
    },
  ],
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <slot name="head" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0F172A" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <JsonLd data={orgLd} />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) return;
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
        els.forEach((el) => io.observe(el));
      })();
    </script>

    <script is:inline>
      // Decode XOR-obfuscated email addresses (cloudflare-style).
      // Replaces visible text + sets href on click only (so scrapers tailing
      // page sources don't get a plain mailto: at all).
      (function () {
        function decode(enc) {
          var k = parseInt(enc.substr(0, 2), 16);
          var out = '';
          for (var i = 2; i < enc.length; i += 2) {
            out += String.fromCharCode(parseInt(enc.substr(i, 2), 16) ^ k);
          }
          return out;
        }
        var nodes = document.querySelectorAll('a.cfemail[data-cfemail]');
        for (var n = 0; n < nodes.length; n++) {
          (function (a) {
            var addr;
            try { addr = decode(a.getAttribute('data-cfemail') || ''); }
            catch (e) { return; }
            if (!addr) return;
            var label = a.getAttribute('data-cflabel') || addr;
            a.textContent = label;
            a.removeAttribute('data-cfemail');
            a.removeAttribute('data-cflabel');
            a.removeAttribute('href');
            a.style.cursor = 'pointer';
            a.addEventListener('click', function (ev) {
              ev.preventDefault();
              window.location.href = 'mailto:' + addr;
            });
            // Keyboard accessibility
            a.setAttribute('role', 'link');
            a.setAttribute('tabindex', '0');
            a.addEventListener('keydown', function (ev) {
              if (ev.key === 'Enter' || ev.key === ' ') {
                ev.preventDefault();
                window.location.href = 'mailto:' + addr;
              }
            });
          })(nodes[n]);
        }
      })();
    </script>
  </body>
</html>
